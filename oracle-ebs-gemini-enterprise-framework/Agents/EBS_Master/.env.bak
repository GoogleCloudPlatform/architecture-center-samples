# Rename this file to .env and fill in your values.

# --- Google Cloud ---
GOOGLE_GENAI_USE_VERTEXAI=true
GOOGLE_CLOUD_PROJECT="oracle-ebs-toolkit-demo"
GOOGLE_CLOUD_PROJECT_NUMBER=119724395047
GOOGLE_CLOUD_LOCATION="northamerica-northeast2"
GOOGLE_CLOUD_BUCKET_NAME="ebs-agent-staging"

# --- Observability ---
GOOGLE_CLOUD_AGENT_ENGINE_ENABLE_TELEMETRY=true
OTEL_INSTRUMENTATION_GENAI_CAPTURE_MESSAGE_CONTENT=true

# --- MCP server endpoints ---
# Use the Cloud Run URLs when running on Agent Engine.
# Use localhost URLs for local development.
#
# SQL MCP server (mcp-oracle-sql)
MCP_SERVER_SQL_URL="https://mcp-oracle-sql-${GOOGLE_CLOUD_PROJECT_NUMBER}.${GOOGLE_CLOUD_LOCATION}.run.app/mcp/"
#MCP_SERVER_SQL_URL="http://localhost:8080/mcp"
#
# EBS REST/SOAP MCP server (mcp-oracle-ebs)
MCP_SERVER_EBS_URL="https://mcp-toolbox-ebs-eoyktoqjhq-pd.a.run.app"
#MCP_SERVER_EBS_URL="http://localhost:8081/mcp"

# Gooogle Cloud authentication settings for agents to identify themselves when calling tools or making requests that require auth.
# Create with manage_oath.sh

# --- Debug ---
DEBUG=false
